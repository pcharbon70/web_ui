{
  "name": "web_ui-assets",
  "version": "1.0.0",
  "description": "WebUI frontend assets (Elm, CSS, JS)",
  "scripts": {
    "build": "npm run build:css",
    "build:css": "npx tailwindcss --input=css/app.css --output=../priv/static/assets/app.css --config=tailwind.config.js",
    "watch:css": "npx tailwindcss --input=css/app.css --output=../priv/static/assets/app.css --config=tailwind.config.js --watch",
    "elm:test": "cd elm && npx elm-test",
    "elm:review": "cd elm && npx elm-review",
    "elm:format": "cd elm && npx elm-format src/ tests/",
    "elm:format:check": "cd elm && npx elm-format --validate src/ tests/"
  },
  "devDependencies": {
    "elm": "^0.19.1-6",
    "esbuild": "^0.27.0",
    "elm-review": "^2.12.0",
    "elm-format": "^0.8.7",
    "elm-test": "^0.19.1-revision12",
    "tailwindcss": "^3.4.18"
  }
}
